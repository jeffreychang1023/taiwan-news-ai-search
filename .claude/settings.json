{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "echo STOP: Use python tools/indexer.py --search instead of Grep. SQLite FTS5 is faster and saves tokens. 1>&2 && exit 2"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/users/user/nlweb/.claude/scripts/py-compile-check.py"
          }
        ]
      }
    ]
  }
}
